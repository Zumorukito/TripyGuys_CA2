<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Trip</title>
</head>
<body>
    <h1>Edit Trip Details</h1>

    <form action="/trips/<%= trip.id %>/edit" method="POST">
        
        <div>
            <label for="destination">Destination:</label>
            <!-- Pre-fill the input with the existing value -->
            <input type="text" id="destination" name="destination" value="<%= trip.destination %>" required>
        </div>

        <div>
            <label for="trip_date">Date:</label>
            <input type="date" id="trip_date" name="trip_date" value="<%= trip.trip_date %>" required>
        </div>

        <div>
            <label for="description">Description:</label>
            <textarea id="description" name="description" required><%= trip.description %></textarea>
        </div>

        <button type="submit">Update Trip</button>
        <a href="/trips">Cancel</a>
    </form>
</body>
</html>