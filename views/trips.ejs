<%- include('partials/header', { pageTitle: isAdminView ? 'Manage Trips' : 'My Trips' }) %>

<main class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h2 mb-1"><%= isAdminView ? 'All User Trips' : 'My Trips' %></h1>
            <p class="text-secondary mb-0">
                <%= isAdminView ? 'Administrator view of all trip records.' : 'Plan and manage your personal travel experiences.' %>
            </p>
        </div>
        <a href="/trips/add" class="btn btn-primary">Add New Trip</a>
    </div>

    <% if (!isAdminView) { %>
        <form class="row g-2 mb-4" method="GET" action="/trips">
            <div class="col-md-6">
                <input type="search" class="form-control" name="search" value="<%= search %>" placeholder="Search trip name or destination">
            </div>
            <div class="col-md-3">
                <select class="form-select" name="status">
                    <option value="">All statuses</option>
                    <% ['Planning', 'Confirmed', 'Completed', 'Cancelled'].forEach((option) => { %>
                        <option value="<%= option %>" <%= status === option ? 'selected' : '' %>><%= option %></option>
                    <% }); %>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" name="budgetRange">
                    <option value="">All Budgets</option>
                    <option value="0-1000" <%= budgetRange === '0-1000' ? 'selected' : '' %>>0 - 1000</option>
                    <option value="1001-2000" <%= budgetRange === '1001-2000' ? 'selected' : '' %>>1001 - 2000</option>
                    <option value="2001-3000" <%= budgetRange === '2001-3000' ? 'selected' : '' %>>2001 - 3000</option>
                    <option value="3001-5000" <%= budgetRange === '3001-5000' ? 'selected' : '' %>>3001 - 5000</option>
                    <option value="5001-+" <%= budgetRange === '5001-+' ? 'selected' : '' %>>5001 and above</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-dark" type="submit">Search</button>
                <a class="btn btn-outline-secondary" href="/trips">Reset</a>
            </div>
        </form>
    <% } %>

    <% if (trips.length === 0) { %>
        <div class="alert alert-info">No trips found.</div>
    <% } else { %>
        <div class="row g-4">
            <% trips.forEach((trip) => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm trip-card">
                        <% if (trip.image) { %>
                            <img src="/images/<%= trip.image %>" class="card-img-top" alt="<%= trip.tripName %>">
                        <% } else { %>
                            <div class="placeholder-image">No trip image</div>
                        <% } %>
                        <div class="card-body">
                            <div class="d-flex justify-content-between gap-2">
                                <h2 class="h5"><%= trip.tripName %></h2>
                                <span class="badge text-bg-secondary align-self-start"><%= trip.status %></span>
                            </div>
                            <% if (isAdminView) { %>
                                <p class="small text-secondary mb-1">Owner: <%= trip.username %></p>
                            <% } %>
                            <p class="mb-1"><strong>Destination:</strong> <%= trip.destination %></p>
                            <p class="mb-1"><strong>Dates:</strong> <%= new Date(trip.startDate).toLocaleDateString('en-SG') %> – <%= new Date(trip.endDate).toLocaleDateString('en-SG') %></p>
                            <p><strong>Budget:</strong> $<%= Number(trip.budget).toFixed(2) %></p>
                            <a href="/trips/<%= trip.tripId %>" class="btn btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
