<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | TripyGuys' : 'TripyGuys' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">TripyGuys</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav ms-auto">
                <% if (!user) { %>
                    <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
                    <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link" href="<%= user.role === 'admin' ? '/admin/trips' : '/trips' %>">Trips</a>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/trips/add">Add Trip</a></li>
                    <li class="nav-item"><a class="nav-link" href="/community">Blogs</a></li>
                    <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-3">
    <% successMessages.forEach((message) => { %>
        <div class="alert alert-success"><%= message %></div>
    <% }); %>

    <% errorMessages.forEach((message) => { %>
        <div class="alert alert-danger"><%= message %></div>
    <% }); %>
</div>