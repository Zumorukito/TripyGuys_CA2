<%- include('partials/header', { pageTitle: trip.tripName }) %>

    <main class="container py-4">
        <div class="card shadow-sm detail-card">
            <% if (trip.image) { %>
                <img src="/images/<%= trip.image %>" class="trip-image card-img-top" alt="<%= trip.tripName %>">
                <% } %>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <h1 class="h2">
                                <%= trip.tripName %>
                            </h1>
                            <span class="badge <%= trip.status === 'Planning' ? 'text-bg-warning' : trip.status === 'Confirmed' ?
                                'text-bg-success' : trip.status === 'Completed' ? 'text-bg-primary' : trip.status === 'Cancelled' ?
                                'text-bg-danger' : 'text-bg-secondary' %> align-self-start">
                                <%= trip.status %>
                            </span>
                        </div>
                        <table class="table table-bordered mt-4">
                            <tbody>
                                <tr>
                                    <th width="30%">Destination:</th>
                                    <td><%= trip.destination %></td>
                                </tr>
                                <tr>
                                    <th>Start Date:</th>
                                    <td><%= new Date(trip.startDate).toLocaleDateString('en-SG') %></td>
                                </tr>
                                <tr>
                                    <th>End Date:</th>
                                    <td><%= new Date(trip.endDate).toLocaleDateString('en-SG') %></td>
                                </tr>
                                <tr>
                                    <th>Budget:</th>
                                    <td>$<%= Number(trip.budget).toFixed(2) %></td>
                                </tr>
                                <tr>
                                    <th>Description:</th>
                                    <td><%= trip.description || 'No description provided.' %></td>
                                </tr>
                            </tbody>
                        </table>
                        <% if (user.userId===trip.userId) { %>
                            <a href="/trips/<%= trip.tripId %>/edit" class="btn btn-primary">Edit Trip</a>
                            <% } %>
                                <% if (user.userId===trip.userId || user.role==='admin' ) { %>
                                    <form action="/trips/<%= trip.tripId %>/delete" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this trip?');">
                                        <button type="submit" class="btn btn-danger">Delete Trip</button>
                                    </form>
                                    <% } %>
                                        <a href="<%= user.role === 'admin' ? '/admin/trips' : '/trips' %>"
                                            class="btn btn-outline-secondary">Back</a>
                    </div>
        </div>
    </main>
    <%- include('partials/footer') %>
