<%- include('partials/header', { pageTitle: post.title }) %>

    <main class="container py-4">

        <a href="/community" class="btn btn-outline-dark btn-sm mb-3">&larr; Back to Community</a>

        <div class="card mb-4">

            <div class="card-body">

                <h1>
                    <%= post.title %>
                </h1>

                <p>
                    <strong>Destination:</strong>
                    <%= post.destination %>
                </p>

                <p class="text-muted">
                    Posted by <%= post.username %>
                </p>

                <hr>

                <p>
                    <%= post.postContent %>
                </p>

                <div class="d-flex align-items-center gap-2">

                    <form method="POST" action="/community/<%= post.postId %>/vote">
                        <input type="hidden" name="voteType" value="up">
                        <button type="submit" class="btn btn-outline-success btn-sm">
                            👍 <%= post.thumbsUp %>
                        </button>
                    </form>

                    <form method="POST" action="/community/<%= post.postId %>/vote">
                        <input type="hidden" name="voteType" value="down">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            👎 <%= post.thumbsDown %>
                        </button>
                    </form>

                </div>

            </div>

        </div>

        <h3>Comments</h3>

        <% if(comments.length===0) { %>

            <div class="alert alert-info">
                No comments yet.
            </div>

            <% } else { %>

                <% comments.forEach(c=> { %>

                    <div class="card mb-2">
                        <div class="card-body">
                            <p class="mb-1">
                                <%= c.comment %>
                            </p>
                            <small class="text-muted">— <%= c.username %></small>
                        </div>
                    </div>

                    <% }) %>

                        <% } %>

                            <form method="POST" action="/community/<%= post.postId %>/comment" class="mt-3">
                                <div class="mb-2">
                                    <textarea name="comment" class="form-control" rows="3"
                                        placeholder="Write a comment..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Post Comment</button>
                            </form>

    </main>

    <%- include('partials/footer') %>