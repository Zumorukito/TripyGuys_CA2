<%- include('partials/header', { pageTitle: 'Home' }) %>

<main class="container hero">
    <div class="row align-items-center g-5">
        <div class="col-lg-7">
            <p class="text-uppercase fw-semibold text-secondary">Travel and experience planning</p>
            <h1 class="display-4 fw-bold">Plan every trip in one organised place.</h1>
            <p class="lead text-secondary">Create trips, track dates and budgets, and manage your travel plans with TripMate.</p>
            <% if (!user) { %>
                <a href="/register" class="btn btn-primary btn-lg me-2">Create Account</a>
                <a href="/login" class="btn btn-outline-dark btn-lg">Login</a>
            <% } else { %>
                <a href="<%= user.role === 'admin' ? '/admin/trips' : '/trips' %>" class="btn btn-primary btn-lg">View Trips</a>
            <% } %>
        </div>
        </div>

<div class="col-lg-5">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h2 class="h4">Welcome to TripyGuys</h2>

            <p class="text-muted">
                TripyGuys is a simple travel planning platform that helps users
                create, manage and organise their trips in one convenient place.
                Users can search for trips, upload travel images and track each
                trip's current status.
            </p>

            <ul class="mb-0">
                <li>Secure registration and login</li>
                <li>User and administrator roles</li>
                <li>Create, view, update and delete trips</li>
                <li>Search and filter trips by status</li>
                <li>Upload images for each trip</li>
            </ul>
        </div>
    </div>
</div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
